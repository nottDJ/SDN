# ============================================
# SDN AI Traffic Management — Environment
# ============================================

# Database
POSTGRES_USER=sdn_admin
POSTGRES_PASSWORD=sdn_secure_pass_2024
POSTGRES_DB=sdn_traffic_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://sdn_admin:sdn_secure_pass_2024@postgres:5432/sdn_traffic_db

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Ryu Controller
RYU_HOST=ryu-controller
RYU_PORT=8080
RYU_API_URL=http://ryu-controller:8080

# ML
MODEL_SAVE_PATH=/app/models
PREDICTION_INTERVAL=5
CONGESTION_THRESHOLD=0.8

# Simulation
SIMULATION_MODE=true
